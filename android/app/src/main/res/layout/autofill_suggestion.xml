<?xml version="1.0" encoding="utf-8"?>
<!-- Outermost layer is transparent and provides the gap between the system
     popup chrome (A) and our visible item (B). RemoteViews ignores layout_margin
     on the root, so we use padding on a no-op outer LinearLayout instead. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="5dp"
        android:paddingEnd="5dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:background="@drawable/autofill_suggestion_wrapper_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="18dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@drawable/autofill_suggestion_bg">

        <ImageView
            android:id="@+id/autofill_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="14dp"
            android:src="@mipmap/ic_launcher_round"
            android:contentDescription="Passwords"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/autofill_primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/autofill_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/autofill_secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/autofill_text_secondary"
                android:textSize="12sp"
                android:singleLine="true"
                android:ellipsize="end"
                android:paddingTop="2dp"/>
        </LinearLayout>
    </LinearLayout>
    </LinearLayout>
</LinearLayout>
